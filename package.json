{
  "name": "sistema",
  "version": "0.1.0",
  "private": true,
  "description": "ERP/MES Sumaré — monorepo (Fase 1: produção + rastreabilidade FSSC 22000)",
  "type": "module",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "pnpm -r --parallel --if-present dev",
    "dev:api": "pnpm --filter @sistema/api dev",
    "dev:web": "pnpm --filter @sistema/web dev",
    "build": "pnpm -r --if-present build",
    "lint": "pnpm -r --if-present lint",
    "typecheck": "pnpm -r --if-present typecheck"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  }
}
